      <caption>Unlock a pass file</caption>
    </screenshot>
    <screenshot>
      <image>https://raw.githubusercontent.com/noobping/keycord/50d4e2443dc0fc0b14d7f715b9557fe24077947e/screenshots/file.png</image>
      <caption>Edit a password entry</caption>
    </screenshot>
