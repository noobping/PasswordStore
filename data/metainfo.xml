      </description>
    </release>
    <release version="0.9.0" date="2026-03-17">
      <description>
        <ul>
          <li>Show disabled options instead of hiding them</li>
          <li>Add tools page</li>
          <li>Add advanced search</li>
          <li>Add optional GPG synchronization</li>
          <li>You can now manage Git remotes</li>
        </ul>
