{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Meson: developer build",
            "type": "shell",
            "command": "${workspaceFolder}/scripts/meson-build-profile.sh",
            "args": [
                "${workspaceFolder}/builddir/developer",
                "developer"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": "$rustc"
        },
        {
            "label": "Meson: release build",
            "type": "shell",
            "command": "${workspaceFolder}/scripts/meson-build-profile.sh",
            "args": [
                "${workspaceFolder}/builddir/release",
                "release"
            ],
            "problemMatcher": "$rustc"
        },
        {
            "label": "Meson: translation build",
            "type": "shell",
            "command": "${workspaceFolder}/scripts/meson-build-profile.sh",
            "args": [
                "${workspaceFolder}/builddir/translation",
                "translation"
            ],
            "problemMatcher": "$rustc"
        }
    ]
}
