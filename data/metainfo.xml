<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>io.github.noobping.keycord</id>

  <name>Keycord</name>
  <summary>Browse and edit password stores</summary>

  <metadata_license>CC0-1.0</metadata_license>
  <project_license>GPL-3.0-only</project_license>

  <developer id="io.github.noobping">
    <name>noobping</name>
  </developer>

  <branding>
    <color type="primary" scheme_preference="light">#99C1F1</color>
    <color type="primary" scheme_preference="dark">#613583</color>
  </branding>

  <recommends>
    <display_length compare="ge">360</display_length>
  </recommends>

  <supports>
    <control>keyboard</control>
    <control>pointing</control>
    <control>touch</control>
  </supports>

  <description>
    <p>Works with password stores that use the standard pass layout, so existing data can stay in place and remain compatible with established workflows.</p>
    <ul>
      <li>Generate passwords and copy usernames, secrets, and one-time codes</li>
      <li>Search across multiple stores</li>
      <li>Find outdated accounts and detect weak passwords</li>
      <li>Work with structured fields or raw pass-file text</li>
      <li>Optional Git and GPG synchronization</li>
      <li>Manage recipients and private keys</li>
      <li>Sign commits and manage Git remotes</li>
    </ul>
  </description>

  <launchable type="desktop-id">io.github.noobping.keycord.desktop</launchable>
  <icon type="stock">io.github.noobping.keycord</icon>

  <provides>
    <binary>keycord</binary>
  </provides>

