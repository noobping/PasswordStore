#: data/metainfo.xml:31
msgid ""
"Works with password stores that use the standard pass layout, so existing "
"data can stay in place and remain compatible with established workflows."
msgstr ""
"Werkt met wachtwoordopslagen die de standaard pass-indeling gebruiken, zodat "
"bestaande gegevens kunnen blijven staan en compatibel blijven met "
"gevestigde werkwijzen."

#: data/metainfo.xml:33
msgid "Generate passwords and copy usernames, secrets, and one-time codes"
msgstr "Genereer wachtwoorden en kopieer gebruikersnamen, geheimen en eenmalige codes"

#: data/metainfo.xml:34
msgid "Search across multiple password stores"
msgstr "Zoek in meerdere wachtwoordopslagen"

#: data/metainfo.xml:35
msgid "Identify outdated accounts and weak passwords"
msgstr "Identificeer verouderde accounts en zwakke wachtwoorden"

#: data/metainfo.xml:36
msgid "Work with both structured fields and raw pass file text"
msgstr "Werk met zowel gestructureerde velden als onbewerkte pass-bestandstekst"

#: data/metainfo.xml:37
msgid "Optionally sync with Git"
msgstr "Synchroniseer optioneel met Git"

#: data/metainfo.xml:38
msgid "Optionally sync with the system keyring"
msgstr "Synchroniseer optioneel met de systeemsleutelbos"

#: data/metainfo.xml:39
msgid "Optionally use layered encryption"
msgstr "Gebruik optioneel gelaagde versleuteling"

#: data/metainfo.xml:40
msgid "Use password-protected or hardware-backed OpenPGP private keys"
msgstr ""
"Gebruik met een wachtwoord beveiligde of door hardware ondersteunde "
"OpenPGP-privésleutels"

#: data/metainfo.xml:41
msgid "Manage recipients and private keys"
